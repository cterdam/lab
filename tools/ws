#!/usr/bin/env bash
# Workspace harness for ~/llz. The workspace is the unit of correctness:
# "green" means every member's full test suite passes against the members
# sitting next to it (doc consumes lab by local path). Run after changing ANY
# member. VCS-agnostic: members may be git repos or not.
#
# Launched from the scratch workspace (cd ~/llz/scratch && bazel run :ws -- test)
# or directly (~/llz/lab/tools/ws test).
set -euo pipefail

if [ -n "${BUILD_WORKSPACE_DIRECTORY:-}" ]; then
  # under `bazel run`, this is the invoking workspace (~/llz/scratch)
  ROOT="$(dirname "$BUILD_WORKSPACE_DIRECTORY")"
else
  # invoked directly: the script lives at <workspace>/lab/tools/ws
  ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
fi
MEMBERS=(doc lab)

cmd="${1:-test}"
case "$cmd" in
  test)
    for m in "${MEMBERS[@]}"; do
      echo "=== $m: bazel test //... ==="
      (cd "$ROOT/$m" && bazel test //...)
    done
    echo "=== workspace green ==="
    ;;
  status)
    for m in "${MEMBERS[@]}"; do
      echo "=== $m ==="
      if [ -d "$ROOT/$m/.git" ]; then
        git -C "$ROOT/$m" status -sb | head -5
      else
        echo "(not under git)"
      fi
    done
    ;;
  *)
    echo "usage: ws [test|status]" >&2
    exit 2
    ;;
esac
