#!/usr/bin/env python3
"""Launch an algo with canonical arg names.

Usage:
    python algo <AlgoName> [param=value ...]
    python algo --list

Examples:
    python algo AswanNormal N=100 M=10 p=0.95 y=0.8
    python algo AswanSim N=50 M=5 p=0.9 y=0.7 num_simulations=500
"""

import inspect
import sys
import typing

# ---------------------------------------------------------------------------
# Parse our argv BEFORE importing src, because src.core.arguments.Arguments
# has cli_parse_args=True and would reject algo-specific params.
# ---------------------------------------------------------------------------
_argv = sys.argv[1:]
sys.argv = sys.argv[:1]

# ---------------------------------------------------------------------------
# Now safe to import the project.
# ---------------------------------------------------------------------------

import asyncio

import src.lib.algo.aswan  # noqa: F401 — register Aswan subclasses
from src.core.util import descendant_classes
from src.lib.algo.algo import Algo, Input, Output

# Auto-generated Dataclass fields to hide from the user.
_AUTO_FIELDS = frozenset({"cls", "sid"})


def _type_name(annotation) -> str:
    """Clean type name for display."""
    return getattr(annotation, "__name__", str(annotation))


def _concrete_algos() -> dict[str, type[Algo]]:
    """Return name -> class for all concrete (non-abstract) Algo subclasses."""
    return dict(
        sorted(
            (
                (name, cls)
                for name, cls in descendant_classes(Algo).items()
                if not inspect.isabstract(cls)
            ),
            key=lambda pair: pair[0],
        )
    )


def _input_output_types(algo_cls: type[Algo]) -> tuple[type[Input], type[Output]]:
    """Derive (InputType, OutputType) from the algo's _run signature."""
    hints = typing.get_type_hints(algo_cls._run)
    return hints["inp"], hints["return"]


def _user_fields(model_cls: type) -> dict:
    """Fields the user should provide (skip auto-generated ones)."""
    return {
        name: field
        for name, field in model_cls.model_fields.items()
        if name not in _AUTO_FIELDS
    }


def _print_list() -> None:
    """Print available algos with input / output schemas."""
    algos = _concrete_algos()
    print("Available algos:\n")
    for name, cls in algos.items():
        inp_type, out_type = _input_output_types(cls)
        inp_fields = _user_fields(inp_type)
        out_fields = _user_fields(out_type)

        print(f"  {name}")

        print(f"    Input ({inp_type.__name__}):")
        for fname, finfo in inp_fields.items():
            tname = _type_name(finfo.annotation)
            req = "required" if finfo.is_required() else f"default={finfo.default}"
            desc = finfo.description or ""
            print(f"      {fname:<20s} {tname:<8s} ({req})  {desc}")

        print(f"    Output ({out_type.__name__}):")
        for fname, finfo in out_fields.items():
            tname = _type_name(finfo.annotation)
            desc = finfo.description or ""
            print(f"      {fname:<20s} {tname:<8s} {desc}")

        print()


def _parse_params(args: list[str]) -> dict[str, str]:
    """Parse key=value pairs from command-line args."""
    params: dict[str, str] = {}
    for a in args:
        if "=" not in a:
            print(f"Error: invalid parameter '{a}' (expected key=value)", file=sys.stderr)
            sys.exit(1)
        key, value = a.split("=", 1)
        params[key] = value
    return params


def main():
    algos = _concrete_algos()

    # Help / list
    if not _argv or _argv[0] in ("--help", "-h"):
        print(__doc__)
        _print_list()
        sys.exit(0)

    if _argv[0] == "--list":
        _print_list()
        sys.exit(0)

    # Resolve algo class
    algo_name = _argv[0]
    if algo_name not in algos:
        print(f"Unknown algo '{algo_name}'", file=sys.stderr)
        print(f"Available: {', '.join(algos)}", file=sys.stderr)
        sys.exit(1)

    algo_cls = algos[algo_name]
    inp_type, _ = _input_output_types(algo_cls)
    params = _parse_params(_argv[1:])

    # Build input — Pydantic coerces strings to the annotated types.
    try:
        inp = inp_type(**params)
    except Exception as e:
        print(f"Input error: {e}", file=sys.stderr)
        sys.exit(1)

    # Run
    algo = algo_cls(logname=f"launch_{algo_name}")
    result = asyncio.run(algo.run(inp))

    # Print output fields to stdout (one per line, key=value).
    for name in _user_fields(type(result.data)):
        print(f"{name}={getattr(result.data, name)}")


if __name__ == "__main__":
    main()
